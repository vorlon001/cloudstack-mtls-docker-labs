# =============================================================================
# .gitignore — исключения для Git
# =============================================================================

# Сертификаты и ключи — НИКОГДА не коммитить!
certs/*.key
certs/*.crt
certs/*.csr
certs/*.srl
certs/*.p12
certs/*.cnf

# Разрешаем коммитить .gitkeep в папке certs
!certs/.gitkeep

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
