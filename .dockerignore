# =============================================================================
# .dockerignore — исключения для Docker-сборки
# =============================================================================

# Сертификаты (монтируются через volume)
certs/

# Клиентский контейнер (собирается из своего контекста)
client/

# Envoy контейнер (собирается из своего контекста)
envoy/

# Скрипты (не нужны внутри контейнера)
scripts/

# Git
.git/
.gitignore

# Документация
README.md
LICENSE

# IDE
.vscode/
.idea/

# Docker
docker-compose.yml
Dockerfile
.dockerignore
