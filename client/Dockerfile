# =============================================================================
# Dockerfile для клиента mTLS-тестирования
# Базируется на alpine с установленным curl
# =============================================================================

FROM alpine:latest

# Устанавливаем curl и ca-certificates
RUN apk add --no-cache curl bash

# Копируем скрипт тестирования
COPY test.sh /test.sh
RUN chmod +x /test.sh

# Скрипт запускается один раз и завершает контейнер
CMD ["/test.sh"]
